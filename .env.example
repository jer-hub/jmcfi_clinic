# Django
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Google OAuth (required for login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ALLOWED_DOMAINS=

# --- Supabase local (after `supabase start` + `supabase status`) ---
# Postgres (local CLI default port 54322)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Supabase API URL (local CLI default port 54321)
SUPABASE_URL=http://127.0.0.1:54321

# Storage — create S3 access keys in Supabase Dashboard → Project Settings → Storage
# Local: use keys from `supabase status` / Studio storage settings when available
USE_SUPABASE_STORAGE=False
SUPABASE_STORAGE_BUCKET=clinic-private
SUPABASE_PUBLIC_STORAGE_BUCKET=clinic-public
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_S3_REGION=local
# Hosted Supabase: use your project's AWS region (Dashboard → Storage), e.g. ap-southeast-1
# If unset, settings infer it from DATABASE_URL pooler host (aws-1-<region>.pooler…)

# Production hosted Supabase: use pooler URL (transaction mode, port 6543), e.g.:
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-1-[region].pooler.supabase.com:5432/postgres

# Tests: leave unset to use SQLite + local filesystem (no supabase start required)
# TEST_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Optional: Redis for Channels (production WebSockets)
# REDIS_URL=redis://127.0.0.1:6379/0

# PDF generation (optional)
# WKHTMLTOPDF_CMD=C:\Program Files\wkhtmltopdf\bin\wkhtmltopdf.exe
